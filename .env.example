# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server/import scripts only — never expose

# Google Workspace OAuth (configured in Supabase Auth providers)
NEXT_PUBLIC_WORKSPACE_DOMAIN=       # e.g. marymount.edu.co  (restricts the account picker)

# Web Push (npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=      # public key — exposed to the browser to subscribe
VAPID_PUBLIC_KEY=                  # same value; used by the Edge Function
VAPID_PRIVATE_KEY=                 # secret — Edge Function only
VAPID_SUBJECT=mailto:admin@school.edu.co
APP_URL=                          # e.g. https://tracker.school.edu.co (deep links)
GOOGLE_CHAT_WEBHOOK_URL=          # optional notification fallback

# The Edge Function reads VAPID_*/APP_URL/GOOGLE_CHAT_WEBHOOK_URL via:
#   supabase secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=... VAPID_SUBJECT=... APP_URL=... GOOGLE_CHAT_WEBHOOK_URL=...
