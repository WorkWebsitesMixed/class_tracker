# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server/import scripts only — never expose

# Google Workspace OAuth (configured in Supabase Auth providers)
NEXT_PUBLIC_WORKSPACE_DOMAIN=       # e.g. marymount.edu.co  (restricts the account picker)

# Web Push (npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
GOOGLE_CHAT_WEBHOOK_URL=            # optional notification fallback
